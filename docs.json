{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BuildCharts",
  "colors": {
    "primary": "#681656",
    "light": "#b71286",
    "dark": "#681656"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "install",
              "guides/how-it-works",
              "guides/examples",
              "considerations"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "core-features/scaffolding",
              "core-features/metadata",
              "core-features/generate",
              "core-features/docker-bake",
              "core-features/summary",
              "charts",
              "core-features/lock-files",
              "core-features/plugins"
            ]
          },
          {
            "group": "How-to Guides",
            "pages": [
              "how-to/define-build-stages",
              "how-to/using-outputs",
              "how-to/handle-dependencies"
            ]
          },
          {
            "group": "Quickstart",
            "pages": [
              "quickstart",
              "guides/github-actions"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "reference/plugin-nuget-authenticate",
              "reference/plugin-testcontainers-dind"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/buildx-history",
              "troubleshooting/common-issues"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "reference/cli"
            ]
          }
        ]
      }
    ],
    "global": {}
  },
  "logo": "/logo/buildcharts.png",
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/eddietisma/buildcharts"
      }
    ],
    "primary": {
      "type": "button",
      "label": "View package",
      "href": "https://www.nuget.org/packages/dotnet-buildcharts"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Packages",
        "items": [
          {
            "label": "NuGet",
            "href": "https://www.nuget.org/packages/dotnet-buildcharts"
          },
          {
            "label": "Docker",
            "href": "https://hub.docker.com/r/buildcharts/buildcharts"
          }
        ]
      }
    ],
    "socials": {
      "github": "https://github.com/eddietisma/buildcharts"
    }
  },
  "appearance": {
    "default": "system"
  },
  "api": {
    "playground": {
      "proxy": true
    }
  },
  "styling": {
    "codeblocks": "dark"
  }
}
