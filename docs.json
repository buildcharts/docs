{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BuildCharts",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#115E59"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "install",
              "guides/how-it-works",
              "guides/github-actions",
              "guides/examples"
            ]
          },
          {
            "group": "Quickstart",
            "pages": [
              "quickstart"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "reference/build-yml",
              "reference/chart-yaml"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "reference/plugins"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "reference/cli"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/eddietisma/buildcharts"
        },
        {
          "anchor": "NuGet",
          "href": "https://www.nuget.org/packages/dotnet-buildcharts"
        }
      ]
    }
  },
  "logo": "/logo/light.svg",
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/eddietisma/buildcharts"
      }
    ],
    "primary": {
      "type": "button",
      "label": "View package",
      "href": "https://www.nuget.org/packages/dotnet-buildcharts"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/eddietisma/buildcharts"
    }
  },
  "appearance": {
    "default": "system"
  },
  "api": {
    "playground": {
      "proxy": true
    }
  }
}
